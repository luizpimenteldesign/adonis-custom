# ADONIS LUTHIERIA — CONFIGURAÇÃO APACHE

Options +FollowSymLinks -Indexes
RewriteEngine On
RewriteBase /

# Força HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Bloqueia arquivos sensíveis
<FilesMatch "\.(env|git|gitignore|htaccess|log|sql|zip|config)$">
    Require all denied
</FilesMatch>

# Bloqueia pasta database
RewriteRule ^database/ - [F,L]

# ROTEAMENTO PRINCIPAL

# Raíz → site institucional (index.html)
RewriteRule ^$ index.html [L]
RewriteRule ^index\.html$ index.html [L]

# /orcamento → formulário de orçamento
RewriteRule ^orcamento/?$ frontend/index.php [L]

# /admin → painel backend
RewriteRule ^admin/?$ backend/admin/login.php [L]

# Se arquivo ou diretório existe, serve diretamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Segurança
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

AddDefaultCharset UTF-8

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>